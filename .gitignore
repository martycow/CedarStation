[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size
[Mm]emory[Cc]aptures/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Autogenerated Vs/MD/Jetbrains
.vs/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/**/[Bb]uildProcessors
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/**/[Ss]ettingsEnvironment.asset
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/**/catalog_*.json
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/**/hash_*.hash
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/**/link.xml
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/**/RemoteCatalog.asset

